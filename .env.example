# =============================================================
# AGP Donor Intelligence — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# =============================================================

# ---- Supabase (required) ------------------------------------
# Found in: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# SERVER-SIDE ONLY — RULES.MD Rule 0:
# This key must ONLY appear in app/api/* route handlers.
# NEVER use it in app/ pages or components/.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Anthropic Claude API (required for AI query) -----------
# SERVER-SIDE ONLY — no NEXT_PUBLIC_ prefix intentionally.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Claude model to use for donor queries
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Application --------------------------------------------
# Values: development | staging | production
NODE_ENV=development
